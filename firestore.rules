rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email_verified == true && 
             request.auth.token.email == 'maheshwari.jahanvi9@gmail.com';
    }

    function isValidLead(data) {
      return data.keys().hasAll(['candidateName', 'fatherName', 'targetExam', 'phoneNumber', 'createdAt']);
    }

    match /leads/{leadId} {
      // Allow anyone to submit a pledge card (unauthenticated)
      allow create: if true;
      // Only admin can read, modify, or delete
      allow read, update, delete: if isAdmin();
    }
  }
}
